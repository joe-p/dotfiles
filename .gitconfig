[user]
    name = Joe Polny
    email = joepolny@gmail.com
    signingkey = "key::ecdsa-sha2-nistp256 AAAAE2VjZHNhLXNoYTItbmlzdHAyNTYAAAAIbmlzdHAyNTYAAABBBEgp4P00th8UgSxKgG8OgKwEM1q94sEIDQwbmdwg/F0rKjE0S+huKa36+x2HpSFYkJ8+3Kb0va26lpv3ecKGWWk="

[commit]
    gpgsign = true

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.gitallowedsigners

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[core]
    hooksPath = /Users/joe/.githooks

[url "git@github.com:"]
    pushInsteadOf = https://github.com/

[alias]
	dft = !git -c diff.external=difft --no-pager diff
